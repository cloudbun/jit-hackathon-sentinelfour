{
  "name": "sentinelfour",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/dev-server.ts & bunx vite",
    "dev:server": "bun run --watch src/dev-server.ts",
    "dev:client": "bunx vite",
    "build": "bunx vite build && bun build src/server.ts --outdir dist/server --target bun",
    "start": "bun dist/server/server.js"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "elysia": "^1.4.27",
    "fast-xml-parser": "^5.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
